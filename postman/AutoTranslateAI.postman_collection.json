            "body": {
              "mode": "raw",
              "raw": "{\n  \"targets\": [\n    {\n      \"platform\": \"YouTube\",\n      \"connectionId\": null,\n      \"title\": \"My dubbed video\",\n      \"description\": \"Made with AutoTranslateAI\",\n      \"tags\": [\n        \"dubbing\",\n        \"vi\"\n      ]\n    },\n    {\n      \"platform\": \"TikTok\",\n      \"connectionId\": null,\n      \"title\": \"My dubbed video\",\n      \"description\": null,\n      \"tags\": []\n    }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('202 Accepted (queued)', () => pm.response.to.have.status(202));",
                  "const j = pm.response.json();",
                  "console.log('queued publish for job', j.jobId, '| status =', j.status);",
                  "pm.test('status = Publishing', () => pm.expect(j.status).to.eql('Publishing'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Poll job status (Publishing → Completed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "console.log('job status =', j.status, '| currentStep =', j.currentStep);",
                  "const publishStep = (j.steps || []).find(s => s.stepType === 'Publish');",
                  "if (publishStep) { console.log('Publish step =', publishStep.status); }",
                  "// Ngay sau POST publish job thường là Publishing; gọi lại vài giây sau sẽ thấy Completed.",
                  "pm.test('status is Publishing or Completed', () =>",
                  "  pm.expect(['Publishing','Completed']).to.include(j.status));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/{{jobId}}",
              "host": [
