        {
          "name": "Get publish results",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/{{jobId}}/publish",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
