            "description": "Poll sau khi Publish job: mỗi nền tảng 1 dòng (Published/Failed + URL/ExternalId hoặc lỗi)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const results = pm.response.json();",
                  "const P = ['YouTube','Facebook','TikTok'];",
                  "const S = ['Pending','Publishing','Published','Failed'];",
                  "results.forEach(r => console.log(P[r.platform] || r.platform, '=>', S[r.status] || r.status, '| url:', r.url, '| err:', r.error));",
                  "// Poll lại tới khi không còn Pending/Publishing (Worker đăng xong).",
                  "const pending = results.filter(r => r.status === 0 || r.status === 1).length;",
                  "console.log('còn đang xử lý:', pending, '/', results.length);",
                  "pm.test('is an array', () => pm.expect(results).to.be.an('array'));"
                ]
              }
            }
          ]
        }
