# Copy to .env and adjust. .env is gitignored — never commit real credentials.
# These power the local docker-compose stack (PostgreSQL + RabbitMQ).

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=ata
POSTGRES_PASSWORD=ata_dev_password
POSTGRES_DB=autotranslateai
POSTGRES_PORT=5432
# Matching .NET connection string for appsettings:
# Host=localhost;Port=5432;Database=autotranslateai;Username=ata;Password=ata_dev_password

# ── RabbitMQ ───────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=ata
RABBITMQ_DEFAULT_PASS=ata_dev_password
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
# Management UI: http://localhost:15672  (login with the user/pass above)

# ── Application (API / Worker) credentials ────────────────
# Used when the API/Worker run *inside Docker* (env vars override appsettings).
# .NET maps the "__" double-underscore to nested config keys.
# For local dev outside Docker, prefer User Secrets instead (see CREDENTIALS.md).
API_PORT=8080
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=autotranslateai;Username=ata;Password=ata_dev_password
RabbitMq__Host=rabbitmq
RabbitMq__Username=ata
RabbitMq__Password=ata_dev_password
OpenAI__ApiKey=
Azure__SpeechKey=
Azure__SpeechRegion=australiaeast
R2__Endpoint=https://<account-id>.r2.cloudflarestorage.com
R2__AccessKeyId=
R2__SecretAccessKey=
R2__BucketName=autotranslate-output
R2__Region=auto
R2__PublicUrl=
