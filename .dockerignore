# Keep the build context small and never bake build output or secrets into the image.
**/bin/
**/obj/
**/.vs/
**/.vscode/
**/.idea/
**/*.user
.git/
.gitignore
.gitattributes
tests/
**/*.md
# Secrets: env files are injected at runtime (env_file), never copied into the image.
.env
.env.*
!.env.example
